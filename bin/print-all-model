#!/usr/bin/env bash
# Print layer structure for all registered BPE models.
#
# For each model in bpe.models.list_models(), runs print-model.py and saves
# the output to <models-dir>/<model>/struct.txt.
#
# Usage:
#   bin/print-all-model
#   bin/print-all-model --models-dir data/models-v1
#   bin/print-all-model --dry-run
#
# Options:
#   --models-dir <path>    Root directory for struct.txt outputs  (default: data/models)
#   --dry-run              Print commands without executing them
#   --input-length N       Forwarded to print-model.py            (default: 1000)
#   --batch-size N         Forwarded to print-model.py            (default: 1)
#   --device cpu|cuda      Forwarded to print-model.py            (default: cpu)

set -euo pipefail
cd "$(dirname "$0")/.."
exec uv run python scripts/print-all-model.py "$@"
