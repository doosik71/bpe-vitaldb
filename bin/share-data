#!/usr/bin/env bash
# Serve the data/ folder over HTTP (multi-threaded, all interfaces).
#
# Usage:
#   bin/share-data [port]
#
#   port defaults to 8888.
#   The LAN address is printed on startup so remote machines know where to connect.

set -euo pipefail

SCRIPT_DIR=$(CDPATH= cd "$(dirname "$0")" && pwd)
cd "$SCRIPT_DIR/.."

exec uv run python scripts/share-data.py ${1+--port "$1"} "${@:2}"
