#!/usr/bin/env bash
# Serve the data/ folder over HTTP using Python's built-in file server.
#
# Usage:
#   bin/share-data [port]
#
#   port defaults to 8000.
#   Browse to http://localhost:PORT/ or share the LAN address shown on screen.

set -euo pipefail

PORT="${1:-8000}"

SCRIPT_DIR=$(CDPATH= cd "$(dirname "$0")" && pwd)
cd "$SCRIPT_DIR/.."

exec uv run python -m http.server "$PORT" --directory data
