#!/usr/bin/env bash
# Evaluate every registered BPE model on the held-out test set.
#
# Enumerates all models from bpe.models.list_models(), skips any model that
# lacks a best.pt checkpoint, then dispatches eval-model.py once per model.
# Runs one job per CUDA device in parallel; falls back to sequential CPU runs.
#
# Usage:
#   bin/eval-all-model [OPTIONS]
#   bin/eval-all-model --models-dir data/models-v1
#   bin/eval-all-model --batch-size 256 --no-normalize
#
# Options:
#   --models-dir <path>    Root directory of trained models  (default: data/models)
#   --poll-sec <secs>      Scheduler polling interval        (default: 2.0)
#   --dry-run              Print commands without launching them
#   --dataset-dir <path>   Forwarded to eval-model.py        (default: data/dataset)
#   --batch-size <N>       Forwarded to eval-model.py        (default: 512)
#   --no-normalize         Forwarded to eval-model.py

set -euo pipefail
cd "$(dirname "$0")/.."
exec uv run python scripts/eval-all-model.py "$@"
